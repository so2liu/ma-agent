{
  "name": "ma-agent",
  "description": "Open-source desktop client for AI coding agents",
  "type": "module",
  "version": "0.1.8",
  "license": "MIT",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "node scripts/preDev.js && electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "pnpm run build && electron-builder --mac --publish always",
    "build:win": "pnpm run build && electron-builder --win --publish always",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location .eslintcache --max-warnings=0",
    "test": "bun test",
    "format": "prettier --experimental-cli --write .",
    "format:check": "prettier --experimental-cli --check --log-level warn .",
    "clean": "rm -rf node_modules out dist .turbo .eslintcache *.tsbuildinfo resources/jq.exe resources/git-portable resources/msys2 resources/.jq-version resources/.git-portable-version resources/.msys2-version"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.85",
    "@anthropic-ai/sdk": "^0.78.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@mariozechner/pi-ai": "^0.61.1",
    "@mariozechner/pi-coding-agent": "^0.61.1",
    "@openai/codex-sdk": "^0.117.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-collection": "^1.1.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/electron": "^7.10.0",
    "@sinclair/typebox": "0.34.49",
    "@tanstack/react-virtual": "^3.13.22",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.141",
    "ansi-to-react": "^6.2.6",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "posthog-node": "^5.28.0",
    "radix-ui": "^1.4.3",
    "streamdown": "^2.5.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "electron-updater": "^6.6.2",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lucide-react": "^0.554.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.1.12"
  },
  "build": {
    "appId": "com.pheuter.claude-agent-desktop",
    "productName": "小马快跑",
    "icon": "static/icon.png",
    "beforeBuild": "scripts/beforeBuild.js",
    "afterPack": "scripts/afterPack.js",
    "afterSign": "scripts/notarize.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "out/node_modules/@img/**/*",
      "out/.claude/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "pheuter",
        "repo": "claude-agent-desktop",
        "releaseType": "release"
      }
    ],
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "electronLanguages": [
        "en",
        "en-US"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSDesktopFolderUsageDescription": "小马快跑需要访问您的桌面文件夹以创建和管理工作区文件。",
        "NSDocumentsFolderUsageDescription": "小马快跑需要访问您的文档文件夹以读写文件。",
        "NSDownloadsFolderUsageDescription": "小马快跑需要访问您的下载文件夹以读写文件。"
      },
      "extraResources": []
    },
    "win": {
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "resources/jq.exe",
          "to": "jq.exe"
        },
        {
          "from": "resources/git-portable",
          "to": "git-portable"
        },
        {
          "from": "resources/msys2",
          "to": "msys2"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false
    }
  }
}
